<template>
  <div class="page">
    <div class="top-row">
      <text class="back-btn" onclick="goBack"><</text>
    </div>

    <div class="mode-row">
      <div class="mode-btn" onclick="startClassic">
        <text class="mode-btn-text">经典</text>
      </div>
      <div class="mode-btn mode-btn-formula" onclick="startFormula">
        <text class="mode-btn-text">公式扫雷</text>
      </div>
    </div>

    <div class="card-area">
      <text class="maker-text" onclick="onMakerTap">制作：tianry</text>
      <text class="win-indicator" if="{{ winPlus }}">⚡ Win Plus 已开启</text>
    </div>

    <div class="skin-row">
      <div class="skin-btn" onclick="cycleSkin">
        <text class="skin-btn-text">切换皮肤</text>
      </div>
      <text class="skin-label">{{ skinName }}</text>
    </div>

    <div class="card-area symbol-card">
