<script>
  import router from '@system.router'
  import storage from '@system.storage'
  import prompt from '@system.prompt'

  export default {
    data: {
      winPlus: false,
      tapCount: 0,
      lastTapTime: 0,
      currentSkin: 0,
      skinName: '默认',
      skinNames: ['默认', 'Number Project', 'Ancient 95', 'Word User Interface']
    },

    onShow() {
      storage.get({
        key: 'winPlus',
        success: (d) => { this.winPlus = (d === 'true') }
      })
      storage.get({
        key: 'skin',
        success: (d) => {
          this.currentSkin = parseInt(d) || 0
          this.skinName = this.skinNames[this.currentSkin]
        }
      })
    },

    goBack() { router.back() },

    startClassic() {
      storage.set({ key: 'formulaMode', value: 'false' })
      router.back()
    },
    startFormula() {
      storage.set({ key: 'formulaMode', value: 'true' })
      router.back()
    },

    onMakerTap() {
      var now = Date.now()
      if (now - this.lastTapTime > 1500) { this.tapCount = 0 }
      this.tapCount++
      this.lastTapTime = now
      if (this.tapCount >= 3) {
        this.tapCount = 0
        if (this.winPlus) {
          this.winPlus = false
          storage.set({ key: 'winPlus', value: 'false' })
          prompt.showToast({ message: 'Normal Plus 一切正常', duration: 2000 })
        } else {
          this.winPlus = true
          storage.set({ key: 'winPlus', value: 'true' })
          prompt.showToast({ message: 'Win Plus 我们赢了', duration: 2000 })
        }
      }
    },

    cycleSkin() {
      this.currentSkin = (this.currentSkin + 1) % 4
      this.skinName = this.skinNames[this.currentSkin]
      storage.set({ key: 'skin', value: String(this.currentSkin) })
      prompt.showToast({ message: '皮肤：' + this.skinName, duration: 1500 })
    }
  }
</script>