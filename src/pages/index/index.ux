<template>
  <div class="page">

    <!-- MENU -->
    <div if="{{view==='menu'}}" class="menu">
      <text class="title">扫雷</text>

      <div class="mbtn" onclick="startClassic()">
        <text class="mt">经典模式</text>
      </div>
      <div class="diff-row">
        <div class="da" onclick="prevDiff()"><text class="dat">&lt;</text></div>
        <text class="dl">{{diffLabel}} · {{diffMines}}雷</text>
        <div class="da" onclick="nextDiff()"><text class="dat">&gt;</text></div>
      </div>

      <div class="mbtn mbtn-c" onclick="startChaos()">
        <text class="mt">混乱模式</text>
        <text class="ms">雷数随机 · 禁作弊</text>
      </div>

      <div class="mbtn mbtn-d" onclick="startDaily()">
        <text class="mt">每日挑战</text>
        <text class="ms">{{dailyText}}</text>
      </div>

      <div class="st-link" onclick="goStats()">
        <text class="st-txt">统计 · {{winRate}}%胜率</text>
      </div>

      <div class="about-link" onclick="goAbout()">
        <text class="about-txt">关于</text>
      </div>

      <text class="cr">制作者: tianry</text>
    </div>

    <!-- GAME -->
    <div if="{{view==='game'}}" class="game">
      <div class="top-bar">
        <text class="tb-back" onclick="backMenu()">&lt;</text>
        <div class="tb-left">
          <div class="mine-dot"></div>
          <text class="tb-mn">{{mineLeft}}{{mode==='chaos'?'?':''}}</text>
        </div>
        <text class="mode-tag {{mode==='chaos'?'tag-c':''}} {{isDaily?'tag-d':''}}">{{modeLabel}}</text>
        <text class="tb-time">{{timerStr}}</text>
      </div>

      <div class="board" style="width:{{boardW}}px;">
        <div for="(ri, row) in board" class="brow">
          <div for="(ci, cell) in row" class="bcell"
               style="width:{{cellSize}}px;height:{{cellSize}}px;background-color:{{cell.bg}};"
               onclick="tap(ri, ci)">
            <text class="bct" style="color:{{cell.tc}};font-size:{{cellFont}}px;">{{cell.ch}}</text>
          </div>
        </div>
      </div>

      <text class="tip" if="{{mode==='chaos'}}">雷位每步变化</text>

      <div class="ctrl">
        <div class="cb {{flagMode?'cbon':''}}" onclick="toggleFlag()">
          <text class="ct">{{flagMode?'旗':'探'}}</text>
        </div>
        <div class="cb {{undoLeft<=0?'cbdis':''}}" onclick="doUndo()">
          <text class="ct {{undoLeft<=0?'ctdis':''}}">撤{{undoLeft}}</text>
        </div>
        <div class="cb" onclick="doRestart()">
          <text class="ct">重来</text>
        </div>
        <div if="{{mode!=='chaos'}}" class="cb {{cheatOn?'cbon':''}}" onclick="toggleCheat()">
          <text class="ct">{{cheatOn?'隐':'看'}}</text>
        </div>
        <div if="{{mode==='chaos'}}" class="cb cbdis">
          <text class="ct ctdis">看</text>
        </div>
      </div>

      <div if="{{gameOver||won}}" class="ov">
        <div class="ov-icon {{won?'ovw':'ovl'}}">
          <text class="ov-ic">{{won?'V':'X'}}</text>
        </div>
        <text class="ovt">{{won?'扫雷成功':'踩雷了'}}</text>
        <text class="ovs" if="{{won}}">{{timerStr}}秒{{isNewRecord?' · 新纪录!':''}}</text>
        <div class="ovb-row">
          <div class="ovb" onclick="doRestart()"><text class="ovbt">再来</text></div>
          <div class="ovb ovb2" onclick="backMenu()"><text class="ovbt ovbt2">菜单</text></div>
        </div>
      </div>
    </div>

    <!-- STATS -->
    <div if="{{view==='stats'}}" class="stats-view">
      <div class="hdr">
        <div class="bk" onclick="closeStats()"><text class="bkt">&lt;</text></div>
        <text class="ht">统计数据</text>
        <div class="ph"></div>
      </div>

      <div class="stbl">
        <div class="sr"><text class="sl">总局数</text><text class="sv">{{stats.total}}</text></div>
        <div class="sr"><text class="sl">胜率</text><text class="sv">{{winRate}}%</text></div>
        <div class="sr"><text class="sl">当前连胜</text><text class="sv">{{stats.streak}}</text></div>
        <div class="sr"><text class="sl">最长连胜</text><text class="sv">{{stats.maxStreak}}</text></div>
        <div class="sr"><text class="sl">总用时</text><text class="sv">{{totalTimeStr}}</text></div>
      </div>

      <div class="stbl">
        <div class="sr"><text class="sl">简单最佳</text><text class="sv">{{bestEasyStr}}</text></div>
        <div class="sr"><text class="sl">普通最佳</text><text class="sv">{{bestNormalStr}}</text></div>
        <div class="sr"><text class="sl">困难最佳</text><text class="sv">{{bestHardStr}}</text></div>
        <div class="sr"><text class="sl">经典胜</text><text class="sv">{{stats.classicWins||0}}</text></div>
        <div class="sr"><text class="sl">混乱胜</text><text class="sv">{{stats.chaosWins||0}}</text></div>
        <div class="sr"><text class="sl">每日完成</text><text class="sv">{{stats.dailyDone||0}}</text></div>
      </div>

      <div class="rst-btn" onclick="resetStats()">
        <text class="rst-txt">重置统计</text>
      </div>
    </div>

  </div>
</template>

<style>
  .page {
    position: absolute;
    width: 466px;
    height: 466px;
    border-radius: 233px;
    background-color: #000000;
    flex-direction: column;
