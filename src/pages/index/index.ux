  }
  .face-btn {
    width: 38px;
    height: 38px;
    border-radius: 19px;
    background-color: rgba(255, 255, 255, 0.06);
    align-items: center;
    justify-content: center;
    border-width: 0px;
    border-color: transparent;
    box-sizing: border-box;
  }
  .face-txt {
    font-size: 22px;
    color: #c8d8f0;
    font-weight: bold;
  }
  .nav-area {
    width: 100%;
    height: 30px;
    align-items: center;
    justify-content: center;
    margin-bottom: 4px;
  }
  .nav-btn {
    font-size: 22px;
    color: #8899bb;
    text-align: center;
    padding: 2px 16px;
    background-color: rgba(255, 255, 255, 0.05);
    border-radius: 12px;
    border-width: 0px;
    border-color: transparent;
    box-sizing: border-box;
  }
  .board-wrap {
    flex: 1;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 0;
  }
  .board {
    flex-direction: column;
    width: 300px;
    height: 300px;
    background-color: #1a1a2e;
    border-radius: 12px;
    padding: 3px;
    box-sizing: border-box;
  }
