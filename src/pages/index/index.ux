    color: #884444;
  }
</style>

<script>
  import storage from '@system.storage'
  import prompt from '@system.prompt'
  import router from '@system.router'

  var DIFFS = [
    { key: "easy", rows: 6, cols: 6, mines: 5, cell: 34, font: 15, label: "简单" },
    { key: "normal", rows: 8, cols: 8, mines: 10, cell: 28, font: 13, label: "普通" },
    { key: "hard", rows: 10, cols: 10, mines: 20, cell: 22, font: 11, label: "困难" }
  ]

  var NUM_CLR = ["", "#5b9bd5", "#5bd58d", "#d55b5b", "#7b5bd5", "#d57b5b", "#5bd5d5", "#999", "#666"]

  function emptyCell() {
    return { mine: false, revealed: false, flagged: false, num: 0, ch: "", bg: "#1a1a2e", tc: "#c8d8f0" }
  }

  function makeBoard(rows, cols) {
    var b = []
    for (var r = 0; r < rows; r++) {
      var row = []
      for (var c = 0; c < cols; c++) row.push(emptyCell())
      b.push(row)
    }
    return b
  }

  function cloneBoard(b) { return JSON.parse(JSON.stringify(b)) }

  function fmtTime(sec) {
    if (!sec || sec <= 0) return "0秒"
    if (sec < 60) return sec + "秒"
    if (sec < 3600) return Math.floor(sec / 60) + "分" + (sec % 60) + "秒"
    return Math.floor(sec / 3600) + "时" + Math.floor((sec % 3600) / 60) + "分"
  }

  var _sd = 0
  function sdInit(s) { _sd = Math.abs(s) % 2147483647; if (_sd === 0) _sd = 1 }
  function sdNext() { _sd = (_sd * 16807) % 2147483647; return (_sd - 1) / 2147483646 }
  function daySeed() {
    var d = new Date()
    return d.getFullYear() * 10000 + (d.getMonth() + 1) * 100 + d.getDate()
  }

  function newStats() {
    return {
      total: 0, wins: 0, streak: 0, maxStreak: 0, time: 0,
      bestEasy: 0, bestNormal: 0, bestHard: 0,
      classicWins: 0, chaosWins: 0, dailyDone: 0
    }
  }

  export default {
    data: {
      view: "menu",
      mode: "normal",
      isDaily: false,
      modeLabel: "经典",
      rows: 8, cols: 8, mines: 10,
      cellSize: 28, cellFont: 13, boardW: 240,
      diffIdx: 1, diffLabel: "普通", diffMines: 10,
      board: [],
      firstClick: true, gameOver: false, won: false,
      flagMode: false, cheatOn: false,
      mineLeft: 10, curMines: 10, flagCnt: 0,
      timer: 0, timerStr: "0", timerRef: null,
      undoStack: [], undoLeft: 3,
      isNewRecord: false, hitR: -1, hitC: -1,
      lastResult: "none", lastTimer: 0,
      stats: null,
      winRate: 0, totalTimeStr: "0秒",
      bestEasyStr: "--", bestNormalStr: "--", bestHardStr: "--",
      dailyText: "今日挑战", dailyDone: false, dailyTime: 0
    },

    onInit() {
      this.stats = newStats()
      this.board = makeBoard(8, 8)
    },

    onShow() {
      var self = this
      storage.get({
        key: "ms_stats",
        success: function (d) {
          if (d) { try { self.stats = JSON.parse(d) } catch (e) { self.stats = newStats() } }
          else self.stats = newStats()
          self.computeDisplay()
        },
        fail: function () { self.stats = newStats(); self.computeDisplay() }
      })
      storage.get({
        key: "ms_daily",
        success: function (d) {
          var today = "" + daySeed()
          if (d) {
            try {
              var o = JSON.parse(d)
              if (o.date === today) {
                self.dailyDone = true; self.dailyTime = o.time
                self.dailyText = "已完成 " + o.time + "秒"
              } else {
                self.dailyDone = false; self.dailyText = "今日挑战"
              }
            } catch (e) { self.dailyDone = false; self.dailyText = "今日挑战" }
          } else { self.dailyDone = false; self.dailyText = "今日挑战" }
        }
      })
      if (this.view === "game" && !this.firstClick && !this.gameOver && !this.won) this.startTimer()
    },

    onHide() {
      this.stopTimer()
      if (this.gameOver || this.won) this.commitResult()
    },

    /* ---- MENU ---- */
    prevDiff() {
      this.diffIdx = this.diffIdx > 0 ? this.diffIdx - 1 : DIFFS.length - 1
      this.applyDiff()
    },
    nextDiff() {
      this.diffIdx = this.diffIdx < DIFFS.length - 1 ? this.diffIdx + 1 : 0
      this.applyDiff()
    },
    applyDiff() {
      var d = DIFFS[this.diffIdx]
      this.diffLabel = d.label
      this.diffMines = d.mines
    },

    startClassic() {
      var d = DIFFS[this.diffIdx]
      this.mode = "normal"; this.isDaily = false; this.modeLabel = "经典"
      this.initGame(d.rows, d.cols, d.mines, d.cell, d.font)
      this.view = "game"
    },
    startChaos() {
      this.mode = "chaos"; this.isDaily = false; this.modeLabel = "混乱"
      this.initGame(8, 8, 10, 28, 13)
      this.view = "game"
    },
    startDaily() {
      if (this.dailyDone) {
        prompt.showToast({ message: "已完成 " + this.dailyTime + "秒", duration: 2000 })
        return
      }
      this.mode = "normal"; this.isDaily = true; this.modeLabel = "每日"
      this.initGame(8, 8, 10, 28, 13)
      this.view = "game"
    },
    goStats() { this.view = "stats" },
    closeStats() { this.view = "menu"; this.computeDisplay() },

    goAbout() {
      router.push({ uri: 'about' })
    },

    /* ---- INIT ---- */
    initGame(rows, cols, mines, cell, font) {
      this.stopTimer()
      this.rows = rows; this.cols = cols; this.mines = mines
      this.cellSize = cell; this.cellFont = font
      this.boardW = cols * (cell + 2)
      this.board = makeBoard(rows, cols)
      this.firstClick = true; this.gameOver = false; this.won = false
      this.flagMode = false; this.cheatOn = false
      this.flagCnt = 0; this.curMines = mines; this.mineLeft = mines
      this.timer = 0; this.timerStr = "0"
      this.undoStack = []; this.undoLeft = 3
      this.isNewRecord = false; this.hitR = -1; this.hitC = -1
      this.lastResult = "none"; this.lastTimer = 0
    },

    /* ---- MINES ---- */
    placeMines(er, ec) {
      var pos = []
      for (var r = 0; r < this.rows; r++)
        for (var c = 0; c < this.cols; c++)
          if (!(r === er && c === ec)) pos.push([r, c])
      if (this.isDaily) {
        sdInit(daySeed())
        for (var i = pos.length - 1; i > 0; i--) {
          var j = Math.floor(sdNext() * (i + 1))
          var t = pos[i]; pos[i] = pos[j]; pos[j] = t
        }
      } else {
        for (var i = pos.length - 1; i > 0; i--) {
          var j = Math.floor(Math.random() * (i + 1))
          var t = pos[i]; pos[i] = pos[j]; pos[j] = t
        }
      }
      for (var i = 0; i < this.curMines; i++)
        this.board[pos[i][0]][pos[i][1]].mine = true
    },

    calcNumbers() {
      for (var r = 0; r < this.rows; r++) {
        for (var c = 0; c < this.cols; c++) {
          if (this.board[r][c].mine) { this.board[r][c].num = -1; continue }
          var cnt = 0
          for (var dr = -1; dr <= 1; dr++)
            for (var dc = -1; dc <= 1; dc++) {
              if (dr === 0 && dc === 0) continue
              var nr = r + dr, nc = c + dc
              if (nr >= 0 && nr < this.rows && nc >= 0 && nc < this.cols)
                if (this.board[nr][nc].mine) cnt++
            }
          this.board[r][c].num = cnt
        }
      }
    },

    /* ---- TAP ---- */
    tap(r, c) {
      if (this.gameOver || this.won) return
      var cell = this.board[r][c]
      if (cell.revealed) return
      if (this.flagMode) {
        this.saveUndo(); this.doFlag(r, c); this.afterAction()
        return
      }
      if (cell.flagged) return
      this.saveUndo()
      if (this.firstClick) {
        this.firstClick = false; this.startTimer()
        this.placeMines(r, c); this.calcNumbers()
      } else if (this.mode === "chaos") {
        this.chaosReshuffle(r, c)
      }
      this.revealCell(r, c); this.afterAction()
    },

    doFlag(r, c) {
      var cell = this.board[r][c]
      if (cell.flagged) { cell.flagged = false; this.flagCnt-- }
      else { cell.flagged = true; this.flagCnt++ }
      this.mineLeft = this.curMines - this.flagCnt
    },

    revealCell(sr, sc) {
      var queue = [[sr, sc]]
      while (queue.length > 0) {
        var pos = queue.shift()
        var cr = pos[0], cc = pos[1]
        if (cr < 0 || cr >= this.rows || cc < 0 || cc >= this.cols) continue
        var cell = this.board[cr][cc]
        if (cell.revealed || cell.flagged) continue
        cell.revealed = true
        if (cell.mine) {
          this.gameOver = true; this.hitR = cr; this.hitC = cc
          this.revealAll(); this.stopTimer(); return
        }
        if (cell.num === 0) {
          for (var dr = -1; dr <= 1; dr++)
            for (var dc = -1; dc <= 1; dc++) {
              if (dr === 0 && dc === 0) continue
              queue.push([cr + dr, cc + dc])
            }
        }
      }
    },

    revealAll() {
      for (var r = 0; r < this.rows; r++)
        for (var c = 0; c < this.cols; c++)
          this.board[r][c].revealed = true
    },

    chaosReshuffle(r, c) {
      for (var i = 0; i < this.rows; i++)
        for (var j = 0; j < this.cols; j++) {
          this.board[i][j].mine = false
          if (!this.board[i][j].revealed) this.board[i][j].flagged = false
        }
      this.flagCnt = 0
      var el = []
      for (var i = 0; i < this.rows; i++)
        for (var j = 0; j < this.cols; j++)
          if (!this.board[i][j].revealed && !(i === r && j === c)) el.push([i, j])
      var mn = Math.max(3, Math.floor(el.length * 0.10))
      var mx = Math.min(25, Math.floor(el.length * 0.35))
      if (mn > mx) mn = mx
      var cnt = mn + Math.floor(Math.random() * (mx - mn + 1))
      if (cnt > el.length) cnt = el.length
      for (var i = el.length - 1; i > 0; i--) {
        var j = Math.floor(Math.random() * (i + 1))
        var t = el[i]; el[i] = el[j]; el[j] = t
      }
      for (var i = 0; i < cnt; i++)
        this.board[el[i][0]][el[i][1]].mine = true
      this.curMines = cnt; this.mineLeft = cnt; this.calcNumbers()
    },

    afterAction() {
      this.updateDisplay(); this.refreshBoard()
      if (this.gameOver) {
        this.lastResult = "lose"; this.lastTimer = this.timer
      } else {
        this.checkWin()
        if (this.won) {
          this.lastResult = "win"; this.lastTimer = this.timer
          this.isNewRecord = this.checkRecordSilent()
        }
      }
    },

    checkWin() {
      for (var r = 0; r < this.rows; r++)
        for (var c = 0; c < this.cols; c++)
          if (!this.board[r][c].revealed && !this.board[r][c].mine) return
      this.won = true; this.stopTimer()
    },

    /* ---- DISPLAY ---- */
    updateDisplay() {
      for (var r = 0; r < this.rows; r++) {
        for (var c = 0; c < this.cols; c++) {
          var cell = this.board[r][c]
          if (cell.revealed) {
            if (cell.mine) {
              cell.ch = "X"
              cell.bg = (r === this.hitR && c === this.hitC) ? "#880000" : "#3a1010"
              cell.tc = "#ff5555"
            } else if (cell.num > 0) {
              cell.ch = "" + cell.num; cell.bg = "#1e1e30"
              cell.tc = NUM_CLR[cell.num] || "#fff"
            } else {
              cell.ch = ""; cell.bg = "#1e1e30"; cell.tc = "#c8d8f0"
            }
          } else if (cell.flagged) {
            cell.ch = "F"; cell.bg = "#1a1a2e"; cell.tc = "#d5b35b"
          } else if (this.cheatOn && this.mode !== "chaos" && cell.mine) {
            cell.ch = "!"; cell.bg = "#2a1a1a"; cell.tc = "#d55b5b"
          } else {
            cell.ch = ""; cell.bg = "#1a1a2e"; cell.tc = "#c8d8f0"
          }
        }
      }
    },

    refreshBoard() { this.board = cloneBoard(this.board) },

    /* ---- CONTROLS ---- */
    toggleFlag() { this.flagMode = !this.flagMode },
    toggleCheat() {
      if (this.mode === "chaos") return
      this.cheatOn = !this.cheatOn
      this.updateDisplay(); this.refreshBoard()
    },

    saveUndo() {
      if (this.undoLeft <= 0) return
      this.undoStack.push(cloneBoard(this.board)); this.undoLeft--
    },

    doUndo() {
      if (this.undoStack.length === 0) return
      this.board = this.undoStack.pop(); this.undoLeft++
      if (this.gameOver || this.won) {
        this.gameOver = false; this.won = false
        this.lastResult = "none"; this.hitR = -1; this.hitC = -1
        if (!this.firstClick) this.startTimer()
      }
      this.updateDisplay(); this.refreshBoard()
    },

    doRestart() {
      this.commitResult()
      if (this.isDaily && this.dailyDone) {
        prompt.showToast({ message: "今日已完成", duration: 1500 })
        this.view = "menu"; this.computeDisplay(); return
      }
      if (this.mode === "chaos") this.initGame(8, 8, 10, 28, 13)
      else if (this.isDaily) this.initGame(8, 8, 10, 28, 13)
      else { var d = DIFFS[this.diffIdx]; this.initGame(d.rows, d.cols, d.mines, d.cell, d.font) }
    },

    backMenu() {
      this.commitResult(); this.stopTimer()
      this.view = "menu"; this.computeDisplay()
    },

    /* ---- TIMER ---- */
    startTimer() {
      this.stopTimer()
      var self = this
      this.timerRef = setInterval(function () {
        self.timer++; self.timerStr = "" + self.timer
      }, 1000)
    },
    stopTimer() {
      if (this.timerRef) { clearInterval(this.timerRef); this.timerRef = null }
    },

    /* ---- STATS ---- */
    commitResult() {
      if (this.lastResult === "win") {
        this.stats.wins++; this.stats.streak++
        if (this.stats.streak > this.stats.maxStreak) this.stats.maxStreak = this.stats.streak
        if (this.mode === "chaos") this.stats.chaosWins = (this.stats.chaosWins || 0) + 1
        else this.stats.classicWins = (this.stats.classicWins || 0) + 1
        if (this.isDaily) {
          this.stats.dailyDone = (this.stats.dailyDone || 0) + 1; this.saveDaily()
        }
        this.stats.time += this.lastTimer
        if (this.mode !== "chaos") {
          var k = this.diffIdx === 0 ? "bestEasy" : (this.diffIdx === 2 ? "bestHard" : "bestNormal")
          if (this.stats[k] === 0 || this.lastTimer < this.stats[k]) this.stats[k] = this.lastTimer
        }
        this.stats.total++; this.saveStats()
      } else if (this.lastResult === "lose") {
        this.stats.total++; this.stats.streak = 0
        this.stats.time += this.lastTimer; this.saveStats()
      }
      this.lastResult = "none"
    },

    checkRecordSilent() {
      if (this.mode === "chaos") return false
      var k = this.diffIdx === 0 ? "bestEasy" : (this.diffIdx === 2 ? "bestHard" : "bestNormal")
      return this.stats[k] === 0 || this.timer < this.stats[k]
    },

    saveStats() {
      storage.set({ key: "ms_stats", value: JSON.stringify(this.stats) })
    },

    resetStats() {
      this.stats = newStats(); this.saveStats(); this.computeDisplay()
      prompt.showToast({ message: "已重置", duration: 1500 })
    },

    saveDaily() {
      storage.set({
        key: "ms_daily",
        value: JSON.stringify({ date: "" + daySeed(), time: this.timer })
      })
      this.dailyDone = true; this.dailyTime = this.timer
      this.dailyText = "已完成 " + this.timer + "秒"
    },

    computeDisplay() {
      var s = this.stats
      this.winRate = s.total > 0 ? Math.round(s.wins / s.total * 100) : 0
      this.totalTimeStr = fmtTime(s.time || 0)
      this.bestEasyStr = s.bestEasy > 0 ? s.bestEasy + "秒" : "--"
      this.bestNormalStr = s.bestNormal > 0 ? s.bestNormal + "秒" : "--"
      this.bestHardStr = s.bestHard > 0 ? s.bestHard + "秒" : "--"
    }
  }
</script>