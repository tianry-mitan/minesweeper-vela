<template>
  <div class="page {{ skinClass }}">

    <div class="header">
      <div class="info-box">
        <text class="info-icon">{{ gi('M') }}</text>
        <text class="info-val {{ remainingMines < 0 ? 'danger' : '' }}">{{ gm() }}</text>
      </div>
      <div class="face-btn" onclick="initGame">
        <text class="face-txt">{{ gf() }}</text>
      </div>
      <div class="info-box">
        <text class="info-icon">{{ gi('T') }}</text>
        <text class="info-val">{{ gt() }}</text>
      </div>
    </div>

    <div class="nav-area">
      <text class="nav-btn" onclick="goToAbout">...</text>
    </div>

    <div class="board-wrap">
      <div class="board">
        <block for="(i, row) in grid">
          <div class="board-row">
            <block for="(j, cell) in row">
              <div class="cell {{ cs(cell) }}"
                   onclick="onCellUp(i, j)"
                   onlongpress="onCellLong(i, j)">
                <text class="num {{ cn(cell) }}">{{ cc(cell) }}</text>
              </div>
            </block>
          </div>
        </block>
      </div>
    </div>

    <div class="footer">
      <div class="flag-btn {{ flagMode ? 'flag-on' : '' }}" onclick="toggleFlag">
        <text class="flag-txt {{ flagMode ? 'flag-txt-on' : '' }}">{{ gfl() }}</text>
      </div>
      <text class="status {{ statusCls }}">{{ gs() }}</text>
    </div>

  </div>
</template>

<style>
  /* ===== LAYOUT ===== */
  .page {
    position: absolute;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    width: 466px;
    height: 466px;
    background-color: #12121f;
    padding: 12px 12px 10px;
    box-sizing: border-box;
  }
  .header {
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    height: 36px;
    margin-bottom: 2px;
    padding: 0 4px;
  }
  .info-box {
    flex-direction: row;
    align-items: center;
    height: 28px;
    padding: 2px 10px;
    background-color: rgba(255, 255, 255, 0.04);
    border-radius: 12px;
    border-width: 0px;
    border-color: transparent;
    box-sizing: border-box;
  }
  .info-icon {
    font-size: 14px;
    color: #8899bb;
    margin-right: 5px;
  }
  .info-val {
    font-size: 16px;
    font-weight: 600;
